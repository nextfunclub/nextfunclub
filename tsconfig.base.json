{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@chill-club/shared": ["packages/shared/src"],
      "@chill-club/shared/*": ["packages/shared/src/*"],
      "@chill-club/ui": ["packages/ui/src"],
      "@chill-club/ui/*": ["packages/ui/src/*"]
    }
  }
}
