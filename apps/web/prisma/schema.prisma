generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ActivityType {
  PUBLIC_EVENT
  USER_HOSTED
  LOCAL
  TRIP
}

enum ActivityCategory {
  BOARD_GAME
  MOVIE
  MUSIC
  SPORTS
  TRAVEL
  FOOD
  EXHIBITION
  OTHER
}

enum PriceType {
  FREE
  AA
  FIXED
  RANGE
}

enum ActivityStatus {
  OPEN
  FULL
  DRAFT
  RECRUITING
  CONFIRMED
  ENDED
  CANCELLED
}

enum ActivityVisibility {
  PUBLIC
  LINK_ONLY
  PRIVATE
}

enum ParticipantStatus {
  JOINED
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum UserProfileStatus {
  ACTIVE
  DELETED
}

enum CommentType {
  QUESTION
  SUGGESTION
  REVIEW
}

model UserProfile {
  id             String                @id @default(cuid())
  clerkUserId    String                @unique
  email          String?
  nickname       String
  firstName      String?
  lastName       String?
  username       String?
  avatarUrl      String?
  bio            String?
  interests      String[]              @default([])
  status         UserProfileStatus     @default(ACTIVE)
  lastSignInAt   DateTime?
  clerkCreatedAt DateTime?
  clerkUpdatedAt DateTime?
  clerkDeletedAt DateTime?
  syncedAt       DateTime?
  activities     Activity[]            @relation("ActivityOrganizer")
  participations ActivityParticipant[]
  comments       Comment[]
  following      UserFollow[]          @relation("UserFollowing")
  followers      UserFollow[]          @relation("UserFollowers")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model Activity {
  id               String                @id @default(cuid())
  title            String
  description      String
  itinerary        String?
  type             ActivityType          @default(LOCAL)
  category         ActivityCategory      @default(OTHER)
  city             String                @default("Paris")
  destination      String?
  address          String
  startAt          DateTime
  endAt            DateTime?
  capacity         Int
  minParticipants  Int?
  requiresApproval Boolean               @default(false)
  priceType        PriceType             @default(FREE)
  priceText        String
  coverImageUrl    String?
  source           String?
  sourceUrl        String?               @unique
  externalSource   String?
  externalId       String?
  externalUrl      String?
  sourcePayload    Json?
  importedAt       DateTime?
  status           ActivityStatus        @default(RECRUITING)
  visibility       ActivityVisibility    @default(PUBLIC)
  organizerId      String
  organizer        UserProfile           @relation("ActivityOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  merchantId       String?
  merchant         Merchant?             @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  participants     ActivityParticipant[]
  comments         Comment[]
  sourceLinks      ActivitySourceLink[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([city, startAt])
  @@index([organizerId])
  @@index([merchantId])
  @@index([source])
  @@index([externalSource, externalId])
  @@index([externalUrl])
  @@index([importedAt])
}

model Merchant {
  id             String     @id @default(cuid())
  slug           String     @unique
  name           String
  description    String
  logoUrl        String?
  city           String     @default("Paris")
  address        String?
  latitude       Float?
  longitude      Float?
  websiteUrl     String?
  contactEmail   String?
  externalSource String?
  externalId     String?
  externalUrl    String?
  sourcePayload  Json?
  importedAt     DateTime?
  isActive       Boolean    @default(true)
  activities     Activity[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([isActive, city])
  @@index([externalSource, externalId])
  @@index([externalUrl])
  @@index([importedAt])
}

model ActivitySourceLink {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  source     String
  sourceUrl  String   @unique
  createdAt  DateTime @default(now())

  @@index([activityId])
}

model ActivityParticipant {
  id            String            @id @default(cuid())
  activityId    String
  userProfileId String
  status        ParticipantStatus @default(APPROVED)
  message       String?
  joinedAt      DateTime          @default(now())
  cancelledAt   DateTime?
  activity      Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  userProfile   UserProfile       @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([activityId, userProfileId])
  @@index([userProfileId])
}

model Comment {
  id                String      @id @default(cuid())
  activityId        String
  authorId          String
  type              CommentType @default(QUESTION)
  content           String
  pinnedByOrganizer Boolean     @default(false)
  activity          Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  author            UserProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([activityId, pinnedByOrganizer, createdAt])
  @@index([authorId])
}

model UserFollow {
  id          String      @id @default(cuid())
  followerId  String
  followingId String
  follower    UserProfile @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   UserProfile @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}
