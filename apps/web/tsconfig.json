{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@chill-club/shared": ["../../packages/shared/src"],
      "@chill-club/shared/*": ["../../packages/shared/src/*"],
      "@chill-club/ui": ["../../packages/ui/src"],
      "@chill-club/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
