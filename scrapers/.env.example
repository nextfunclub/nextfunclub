# Prefer reading Supabase config from ../apps/web/.env.local in the monorepo.
# If you split this folder to another repository, copy these values here instead.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Optional override for where to load environment variables from.
# Defaults try: ../apps/web/.env.local, ../.env.local, ./.env.local
SCRAPERS_ENV_FILE=

# System organizer profile used for imported activities.
SCRAPER_ORGANIZER_CLERK_USER_ID=scraper-import-bot
SCRAPER_ORGANIZER_NICKNAME=Imported Paris Events

# Crawler settings
SCRAPER_MAX_SORTIR_PAGES=3
SCRAPER_MAX_SORTIR_ARTICLES=24
SCRAPER_MAX_PLAYIN_EVENTS=30
SCRAPER_TIMEOUT_MS=30000
SCRAPER_DELAY_MS=800
SCRAPER_DEFAULT_CAPACITY=100
LOG_LEVEL=info
